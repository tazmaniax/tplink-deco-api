# Copy to .env, replace every CHANGE_ME value and TEST-NET address, then chmod 600 .env.
DECO_HOST=192.168.68.1
DECO_USERNAME=admin
DECO_PASSWORD=CHANGE_ME
DECO_TIMEOUT=60

# Streamable HTTP endpoint. Replace the TEST-NET address with the Docker host's static LAN address.
DECO_MCP_TRANSPORT=streamable-http
DECO_MCP_HOST=0.0.0.0
DECO_MCP_PORT=8000
DECO_MCP_BIND_ADDRESS=192.0.2.10
DECO_MCP_STREAMABLE_HTTP_PATH=/mcp
DECO_MCP_PUBLIC_URL=http://192.0.2.10:8000/mcp
DECO_MCP_ALLOWED_HOSTS=192.0.2.10:8000,127.0.0.1:8000,localhost:8000
DECO_MCP_ALLOWED_ORIGINS=

# Generate with: openssl rand -hex 32
DECO_MCP_BEARER_TOKEN=CHANGE_ME_AT_LEAST_32_CHARACTERS

# Conservative data and mutation gates.
DECO_MCP_ALLOW_SENSITIVE_READS=0
DECO_MCP_ALLOW_BULK_SECRET_READS=0
DECO_MCP_ALLOW_BINARY_CONTENT=0
DECO_MCP_ALLOW_MUTATIONS=0
DECO_MCP_ALLOW_HTTP_NOOP_VERIFICATION=0
DECO_MCP_ALLOW_DESTRUCTIVE=0
DECO_MCP_ALLOW_INTERNAL=0

# Optional TMP/AppV2 transport.
DECO_TP_LINK_ID=
DECO_TMP_HOST_KEY_SHA256=
DECO_MCP_ALLOW_TMP_READS=0
DECO_MCP_ALLOW_UNVERIFIED_TMP_READS=0
DECO_MCP_ALLOW_TMP_NOOP_VERIFICATION=0

# Diagnostic and raw mutation discoverability.
DECO_MCP_EXPOSE_DIAGNOSTIC_TOOLS=0
DECO_MCP_EXPOSE_RAW_MUTATION_TOOLS=0
